{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "artifacts_mmog_adventurer",
  "description": "Adventurer persona for ArtifactsMMO. One episode: task_cycle (accept) → fight chickens → farm copper → bank → task_cycle (complete). Zone enum and action set match ArtifactsMmog.Domain.build/2 exactly.",
  "enums": {
    "zone": {
      "bank": 0,
      "copper_rocks": 1,
      "iron_rocks": 2,
      "coal_rocks": 3,
      "ash_trees": 4,
      "birch_trees": 5,
      "spruce_trees": 6,
      "sunflowers": 7,
      "chickens": 8,
      "pigs": 9,
      "goblins": 10,
      "wolverines": 11,
      "gudgeon": 12,
      "task_master": 13
    }
  },
  "variables": [
    {"name": "zone", "init": {"adventurer": 0}},
    {"name": "hp", "init": {"adventurer": 80}},
    {"name": "max_hp", "init": {"adventurer": 80}},
    {"name": "inv_count", "init": {"adventurer": 0}},
    {"name": "inv_max", "init": {"adventurer": 80}},
    {"name": "has_task", "init": {"adventurer": 0}}
  ],
  "actions": {
    "a_move": {
      "params": ["char", "dest"],
      "body": [{"set": "/zone/{char}", "value": "{dest}"}]
    },
    "a_gather": {
      "params": ["char"],
      "bind": [{"name": "imax", "pointer": "/inv_max/{char}"}],
      "body": [
        {"check": "/inv_count/{char}", "lt": "{imax}"},
        {
          "set": "/inv_count/{char}",
          "value": {
            "op": "add",
            "a": {"op": "get", "pointer": "/inv_count/{char}"},
            "b": 1
          }
        }
      ]
    },
    "a_fight": {
      "params": ["char"],
      "body": [{"check": "/hp/{char}", "ge": 1}]
    },
    "a_rest": {
      "params": ["char"],
      "body": [
        {"set": "/hp/{char}", "value": {"op": "get", "pointer": "/max_hp/{char}"}}
      ]
    },
    "a_bank_deposit": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}", "eq": 0},
        {"set": "/inv_count/{char}", "value": 0}
      ]
    },
    "a_accept_task": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}", "eq": 13},
        {"check": "/has_task/{char}", "eq": 0},
        {"set": "/has_task/{char}", "value": 1}
      ]
    },
    "a_complete_task": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}", "eq": 13},
        {"check": "/has_task/{char}", "eq": 1},
        {"set": "/has_task/{char}", "value": 0}
      ]
    }
  },
  "methods": {
    "go_to_bank": {
      "params": ["char"],
      "alternatives": [
        {
          "name": "already_there",
          "check": [{"pointer": "/zone/{char}", "eq": 0}],
          "subtasks": []
        },
        {"name": "travel", "subtasks": [["a_move", "{char}", 0]]}
      ]
    },
    "ensure_rested": {
      "params": ["char"],
      "alternatives": [
        {
          "name": "hp_full",
          "bind": [{"name": "mhp", "pointer": "/max_hp/{char}"}],
          "check": [{"pointer": "/hp/{char}", "ge": "{mhp}"}],
          "subtasks": []
        },
        {"name": "rest_first", "subtasks": [["a_rest", "{char}"]]}
      ]
    },
    "bank_if_full": {
      "params": ["char"],
      "alternatives": [
        {
          "name": "has_space",
          "bind": [{"name": "imax", "pointer": "/inv_max/{char}"}],
          "check": [{"pointer": "/inv_count/{char}", "lt": "{imax}"}],
          "subtasks": []
        },
        {
          "name": "deposit",
          "subtasks": [["go_to_bank", "{char}"], ["a_bank_deposit", "{char}"]]
        }
      ]
    },
    "farm_resources": {
      "params": ["char", "zone_id"],
      "alternatives": [
        {
          "name": "batch",
          "subtasks": [
            ["bank_if_full", "{char}"],
            ["a_move", "{char}", "{zone_id}"],
            ["a_gather", "{char}"],
            ["a_gather", "{char}"],
            ["a_gather", "{char}"],
            ["a_gather", "{char}"],
            ["a_gather", "{char}"]
          ]
        }
      ]
    },
    "fight_monsters": {
      "params": ["char", "zone_id"],
      "alternatives": [
        {
          "name": "batch",
          "subtasks": [
            ["ensure_rested", "{char}"],
            ["bank_if_full", "{char}"],
            ["a_move", "{char}", "{zone_id}"],
            ["a_fight", "{char}"],
            ["a_fight", "{char}"],
            ["a_fight", "{char}"],
            ["a_fight", "{char}"],
            ["a_fight", "{char}"]
          ]
        }
      ]
    },
    "rest_at_bank": {
      "params": ["char"],
      "alternatives": [
        {
          "name": "safe",
          "subtasks": [
            ["go_to_bank", "{char}"],
            ["ensure_rested", "{char}"]
          ]
        }
      ]
    },
    "task_cycle": {
      "params": ["char"],
      "alternatives": [
        {
          "name": "accept",
          "check": [{"pointer": "/has_task/{char}", "eq": 0}],
          "subtasks": [
            ["go_to_bank", "{char}"],
            ["a_bank_deposit", "{char}"],
            ["a_move", "{char}", 13],
            ["a_accept_task", "{char}"]
          ]
        },
        {
          "name": "complete",
          "check": [{"pointer": "/has_task/{char}", "eq": 1}],
          "subtasks": [
            ["a_move", "{char}", 13],
            ["a_complete_task", "{char}"]
          ]
        }
      ]
    },
    "adventurer_episode": {
      "description": "One full adventurer episode: accept task, fight chickens, farm copper, bank, complete task.",
      "params": ["char"],
      "alternatives": [
        {
          "name": "fresh",
          "check": [{"pointer": "/has_task/{char}", "eq": 0}],
          "subtasks": [
            ["task_cycle", "{char}"],
            ["fight_monsters", "{char}", 8],
            ["farm_resources", "{char}", 1],
            ["go_to_bank", "{char}"],
            ["a_bank_deposit", "{char}"],
            ["task_cycle", "{char}"]
          ]
        },
        {
          "name": "ongoing",
          "check": [{"pointer": "/has_task/{char}", "eq": 1}],
          "subtasks": [
            ["fight_monsters", "{char}", 8],
            ["farm_resources", "{char}", 1],
            ["go_to_bank", "{char}"],
            ["a_bank_deposit", "{char}"],
            ["task_cycle", "{char}"]
          ]
        }
      ]
    }
  },
  "tasks": [["adventurer_episode", "adventurer"]]
}

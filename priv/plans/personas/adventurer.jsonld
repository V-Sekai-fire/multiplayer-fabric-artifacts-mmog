{
  "@context": {
    "khr": "https://registry.khronos.org/glTF/extensions/2.0/KHR_interactivity/",
    "domain": "khr:planning/domain/"
  },
  "@type": "domain:Definition",
  "name": "artifacts_mmog_adventurer",
  "description": "Adventurer persona for ArtifactsMMO. One episode: accept task → rest → fight chickens (5x) → farm copper (3x) → bank → complete task. Zone enum and action set match ArtifactsMmog.Domain.build/2 exactly.",
  "enums": {
    "zone": {
      "bank":         0,
      "copper_rocks": 1,
      "iron_rocks":   2,
      "coal_rocks":   3,
      "ash_trees":    4,
      "birch_trees":  5,
      "spruce_trees": 6,
      "sunflowers":   7,
      "chickens":     8,
      "pigs":         9,
      "goblins":      10,
      "wolverines":   11,
      "gudgeon":      12,
      "task_master":  13
    }
  },
  "variables": [
    {"name": "zone",      "init": {"adventurer": 0}},
    {"name": "hp",        "init": {"adventurer": 80}},
    {"name": "max_hp",    "init": {"adventurer": 80}},
    {"name": "inv_count", "init": {"adventurer": 0}},
    {"name": "inv_max",   "init": {"adventurer": 80}},
    {"name": "has_task",  "init": {"adventurer": 0}}
  ],
  "actions": {
    "a_move": {
      "params": ["char", "dest"],
      "body": [{"set": "/zone/{char}", "value": "{dest}"}]
    },
    "a_gather": {
      "params": ["char"],
      "bind": [{"name": "imax", "pointer": "/inv_max/{char}"}],
      "body": [
        {"check": "/inv_count/{char}", "lt": "{imax}"},
        {"set": "/inv_count/{char}",
         "value": {"type": "math/add",
                   "a": {"type": "pointer/get", "pointer": "/inv_count/{char}"},
                   "b": 1}}
      ]
    },
    "a_fight": {
      "params": ["char"],
      "body": [{"check": "/hp/{char}", "ge": 1}]
    },
    "a_rest": {
      "params": ["char"],
      "body": [{"set": "/hp/{char}",
                "value": {"type": "pointer/get", "pointer": "/max_hp/{char}"}}]
    },
    "a_bank_deposit": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}", "eq": 0},
        {"set": "/inv_count/{char}", "value": 0}
      ]
    },
    "a_accept_task": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}",     "eq": 13},
        {"check": "/has_task/{char}", "eq": 0},
        {"set":   "/has_task/{char}", "value": 1}
      ]
    },
    "a_complete_task": {
      "params": ["char"],
      "body": [
        {"check": "/zone/{char}",     "eq": 13},
        {"check": "/has_task/{char}", "eq": 1},
        {"set":   "/has_task/{char}", "value": 0}
      ]
    }
  },
  "methods": {
    "go_to_bank": {
      "params": ["char"],
      "alternatives": [
        {"name": "already_there",
         "check":    [{"pointer": "/zone/{char}", "eq": 0}],
         "subtasks": []},
        {"name": "travel",
         "subtasks": [["a_move", "{char}", 0]]}
      ]
    },
    "ensure_rested": {
      "params": ["char"],
      "alternatives": [
        {"name": "hp_full",
         "bind":    [{"name": "mhp", "pointer": "/max_hp/{char}"}],
         "check":   [{"pointer": "/hp/{char}", "ge": "{mhp}"}],
         "subtasks": []},
        {"name": "rest_first",
         "subtasks": [["a_rest", "{char}"]]}
      ]
    },
    "bank_if_full": {
      "params": ["char"],
      "alternatives": [
        {"name": "has_space",
         "bind":    [{"name": "imax", "pointer": "/inv_max/{char}"}],
         "check":   [{"pointer": "/inv_count/{char}", "lt": "{imax}"}],
         "subtasks": []},
        {"name": "deposit",
         "subtasks": [["go_to_bank", "{char}"], ["a_bank_deposit", "{char}"]]}
      ]
    },
    "adventurer_episode": {
      "description": "One full adventurer episode. Accepts a task if none is active, fights chickens, farms copper, banks, then completes the task.",
      "params": ["char"],
      "alternatives": [
        {
          "name": "fresh",
          "check": [{"pointer": "/has_task/{char}", "eq": 0}],
          "subtasks": [
            ["a_move",          "{char}", 13],
            ["a_accept_task",   "{char}"],
            ["ensure_rested",   "{char}"],
            ["a_move",          "{char}", 8],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["bank_if_full",    "{char}"],
            ["a_move",          "{char}", 1],
            ["a_gather",        "{char}"],
            ["a_gather",        "{char}"],
            ["a_gather",        "{char}"],
            ["go_to_bank",      "{char}"],
            ["a_bank_deposit",  "{char}"],
            ["a_move",          "{char}", 13],
            ["a_complete_task", "{char}"]
          ]
        },
        {
          "name": "ongoing",
          "check": [{"pointer": "/has_task/{char}", "eq": 1}],
          "subtasks": [
            ["ensure_rested",   "{char}"],
            ["bank_if_full",    "{char}"],
            ["a_move",          "{char}", 8],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["a_fight",         "{char}"],
            ["bank_if_full",    "{char}"],
            ["a_move",          "{char}", 1],
            ["a_gather",        "{char}"],
            ["a_gather",        "{char}"],
            ["a_gather",        "{char}"],
            ["go_to_bank",      "{char}"],
            ["a_bank_deposit",  "{char}"],
            ["a_move",          "{char}", 13],
            ["a_complete_task", "{char}"]
          ]
        }
      ]
    }
  },
  "tasks": [["adventurer_episode", "adventurer"]]
}
